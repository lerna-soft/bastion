<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft glow behind the shield (faked with a wide translucent stroke) -->
    <path
        android:pathData="M54,24 L78,33 L78,52 C78,72 66,82 54,88 C42,82 30,72 30,52 L30,33 Z"
        android:strokeColor="#4AA8FF"
        android:strokeAlpha="0.16"
        android:strokeWidth="7"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Shield outline: cyan -> teal gradient -->
    <path
        android:pathData="M54,24 L78,33 L78,52 C78,72 66,82 54,88 C42,82 30,72 30,52 L30,33 Z"
        android:strokeWidth="3"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="30" android:startY="24"
                android:endX="78" android:endY="88"
                android:startColor="#4AA8FF"
                android:endColor="#35E0C8" />
        </aapt:attr>
    </path>

    <!-- Terminal prompt chevron ">" -->
    <path
        android:pathData="M42,46 L52,54 L42,62"
        android:strokeWidth="4.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="42" android:startY="46"
                android:endX="52" android:endY="62"
                android:startColor="#4AA8FF"
                android:endColor="#35E0C8" />
        </aapt:attr>
    </path>

    <!-- Terminal cursor "_" -->
    <path
        android:pathData="M56,62 L68,62"
        android:strokeColor="#35E0C8"
        android:strokeWidth="4.2"
        android:strokeLineCap="round" />
</vector>
